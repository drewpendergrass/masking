#!/bin/bash

#SBATCH -c 1
#SBATCH -N 1
#SBATCH -t 0-04:00
#SBATCH --account nsoeclimate
#SBATCH -p nsoeclimate,scavenger
#SBATCH --mem=4000
#SBATCH --mail-type=END
#SBATCH --array=0-143

source /work/ap851/CHEEREIO/IASI_full_v03_19a_BACKUP/CHEEREIO/environments/cheereio.env #This is specific to the Harvard cluster; rewrite for yours
